# HTTP port the API listens on (PM2 / systemd starts node here)
PORT=4000

# Allowed origins for the contact endpoint (comma separated)
CORS_ORIGINS=https://devpilotx.com,https://www.devpilotx.com,http://localhost:3000

# Postgres on this VPS
DATABASE_URL=postgresql://devpilotx:CHANGE_ME@127.0.0.1:5432/devpilotx?schema=public

# Hostinger SMTP (Business plan mailboxes)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@devpilotx.com
SMTP_PASS=

# From addresses and internal notification target
MAIL_FROM_CONTACT=DevPilotX <contact@devpilotx.com>
MAIL_FROM_NOREPLY=DevPilotX <noreply@devpilotx.com>
CONTACT_NOTIFY_TO=admin@devpilotx.com
