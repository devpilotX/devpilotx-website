# Hostinger Apache: serve the Next.js static export with friendly URLs.
Options -MultiViews
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Drop a trailing /index.html if it ever sneaks in.
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*?)index\.html$ /$1 [L,R=301,NE]

# Try the requested path, then path with a trailing slash, then path/index.html.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+?)/?$ /$1/index.html [L]

# Long-cache the Next.js asset chunks; they are content-hashed.
<IfModule mod_headers.c>
  <FilesMatch "^.+\.(?:js|css|woff2?|png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html|xml|txt|webmanifest|json)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

ErrorDocument 404 /not-found/index.html
