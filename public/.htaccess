# Hostinger Apache: serve the Next.js static export with friendly URLs.
Options -MultiViews
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Drop a trailing /index.html if it ever sneaks in.
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*?)index\.html$ /$1 [L,R=301,NE]

# Safari/iOS auto-requests /apple-touch-icon.png even when not in HTML.
RewriteRule ^apple-touch-icon\.png$ /apple-touch-icon.svg [L]
RewriteRule ^apple-touch-icon-precomposed\.png$ /apple-touch-icon.svg [L]

# Try the requested path, then path with a trailing slash, then path/index.html.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+?)/?$ /$1/index.html [L]

<IfModule mod_headers.c>
  # Hashed, immutable assets under /_next/static: cache forever (filename hash
  # changes on every rebuild, so this is always safe).
  <FilesMatch "\.(?:js|css|woff2?|png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: never cache anywhere. The home page bug we hit on 2026-05-27 was
  # HCDN edge caching index.html with s-maxage=1y, so subsequent deploys
  # left it pointing at chunk hashes that had been deleted. These directives
  # cover every CDN dialect we have seen:
  #   * Cache-Control: no-store     -> browsers + most CDNs
  #   * Surrogate-Control: no-store -> RFC 3174, respected by HCDN
  #   * CDN-Cache-Control: no-store -> Cloudflare/HCDN newer dialect
  #   * Pragma + Expires            -> HTTP/1.0 fallback
  # 'Header always' overrides upstream/runtime defaults.
  <FilesMatch "\.html$">
    Header always unset Cache-Control
    Header always unset Surrogate-Control
    Header always unset CDN-Cache-Control
    Header always unset Expires
    Header always unset Pragma
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, private"
    Header always set Surrogate-Control "no-store"
    Header always set CDN-Cache-Control "no-store"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set Vary "*"
  </FilesMatch>

  # Manifests, sitemaps, robots: short cache.
  <FilesMatch "\.(?:xml|txt|webmanifest|json)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

ErrorDocument 404 /not-found/index.html
